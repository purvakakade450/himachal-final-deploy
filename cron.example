# Run after each physical model NetCDF drop (adjust paths)
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

# Daily at 06:30 IST after model completes (~01:00 UTC)
30 1 * * * cd /var/www/monsoon-forecast-portal && /usr/bin/python3 -m etl.process_forecast --nc /data/model/latest_forecast.nc >> /var/log/monsoon-etl.log 2>&1

# Restart API optional if using process manager; systemd recommended instead
